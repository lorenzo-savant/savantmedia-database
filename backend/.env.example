# ════════════════════════════════════════════════════════════════
# Savantsdatabas backend — env template
# Copia in `.env` e popola.
# ════════════════════════════════════════════════════════════════

# ─── Supabase (DB target) ──────────────────────────────────────
# Stessa istanza usata dal frontend. La SECRET_KEY bypassa RLS,
# necessaria per gli script di import bulk.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxx

# ─── T0 Open Data — Bolagsverket / SCB bulk files ──────────────
# URL ufficiali (CC-BY-4.0, gratis dal feb 2025).
# Lasciali com'è a meno che Bolagsverket non cambi indirizzo.
BOLAGSVERKET_BULK_URL=https://vardefulla-datamangder.bolagsverket.se/bolagsverket/bolagsverket_bulkfil.zip
SCB_BULK_URL=https://vardefulla-datamangder.bolagsverket.se/scb/scb_bulkfil.zip

# Cartella locale per cache dei file scaricati (gitignored)
BULK_CACHE_DIR=./data/bulk

# ─── T3 crawl4ai — LLM-driven extraction ───────────────────────
# Default è Ollama locale (cost-zero); Groq come fallback cloud.
# Lascia vuoto se vuoi solo markdown extraction senza schema LLM.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_REASONING=llama3.1:8b
GROQ_API_KEY=

# ─── Fase 11 — Memory writer (vault + pgvector) ────────────────
# Path al vault Obsidian. L'agente legge i playbook e scrive SOLO
# in `{VAULT_PATH}/Workflows/scraping-runs/` — mai modifiche altrove.
# Embeddings: nomic-embed-text via Ollama (768-dim).
VAULT_PATH=C:/Users/loren/Desktop/lorenzovault

# ─── Memo: deps future (non lette ora, ma vivranno qui) ────────
# REDIS_URL=redis://localhost:6379/0
# SEARXNG_URL=http://localhost:8888
