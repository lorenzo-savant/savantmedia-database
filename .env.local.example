# ════════════════════════════════════════════════════════════════
# Savantsdatabas — template ambiente
# ────────────────────────────────────────────────────────────────
# Copia questo file in `.env.local` e popola i valori reali.
# `.env.local` è ignorato da git: i tuoi secret restano locali.
#
# Variabili `NEXT_PUBLIC_*` sono esposte al browser.
# Tutte le altre sono server-side only.
# ════════════════════════════════════════════════════════════════


# ─── Supabase (DB condiviso + Auth + Realtime + pgvector) ──────
# Crea un progetto free su https://supabase.com → Settings → API Keys
# Usa la nuova nomenclatura: "Publishable key" + "Secret key"
# (le vecchie "anon" e "service_role" JWT funzionano ancora ma sono deprecate).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxx

# Secret key: server-only, mai esposta al client (bypassa RLS).
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxx


# ─── Backend FastAPI orchestrator (Fase 5+ del design doc) ─────
NEXT_PUBLIC_ORCHESTRATOR_URL=http://localhost:8000
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# or (PowerShell, no deps):
#   $b = New-Object byte[] 32; [System.Security.Cryptography.RandomNumberGenerator]::Create().GetBytes($b); -join ($b | ForEach-Object { '{0:x2}' -f $_ })
ORCHESTRATOR_API_TOKEN=


# ─── Memo: variabili future per backend/.env (non lette da Next) ─
# GROQ_API_KEY=gsk_...
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL_REASONING=llama3.1:8b
# OLLAMA_MODEL_EMBED=nomic-embed-text
# REDIS_URL=redis://localhost:6379/0
# SEARXNG_URL=http://localhost:8888
# DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres
# SERPAPI_KEY_1=
# APIVERKET_API_KEY=sk_test_demo
